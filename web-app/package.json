{
  "name": "web-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "ingest": "bun scripts/ingest-coach.ts",
    "verify:e041": "bun scripts/verify-e041.ts",
    "verify:e044": "bun scripts/verify-e044.ts",
    "verify:e046:assets": "bun scripts/verify-e046-assets.ts",
    "prebuild:cf": "bun scripts/prebuild-cf.ts",
    "build:cf": "bun scripts/cf-build.ts",
    "preview:cf": "bun run ingest && bun run prebuild:cf && bun run build:cf && opennextjs-cloudflare preview",
    "deploy:cf": "bun run ingest && bun run prebuild:cf && bun run build:cf && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv app/lib/runtime/cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.0",
    "next": "^16.2.0",
    "nuqs": "^2.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sqlocal": "^0.18.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@opennextjs/aws": "^3.7.0",
    "@opennextjs/cloudflare": "^1.19.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
