# OpenRouter API key. Get one at https://openrouter.ai. Server-only — never
# prefix with NEXT_PUBLIC_, never reference from client components.
OPENROUTER_API_KEY=

# Anthropic API key — used by the v5b retrieval pipeline (E-043) for the
# seed-detection (Haiku) + walker (Sonnet) calls. The coach turn itself
# routes through OpenRouter; only the retrieval planner goes direct to
# Anthropic so the @ai-sdk/anthropic prompt-cache markers attach correctly.
ANTHROPIC_API_KEY=

# Optional: identifier surfaced in OpenRouter analytics so multiple apps
# sharing one key can be distinguished.
APP_URL=http://localhost:3000

# Optional: process-level cumulative-cost circuit breaker (USD). When total
# spend (retrieval + coach) since the process started exceeds this, the
# /api/chat route returns 503 until the process is restarted. Default $5.
# OPENROUTER_DAILY_CAP=5

# Optional: override the wiki content directory. Defaults to
# `<cwd>/content/wiki`. Useful when running the server from a different
# working directory in tests.
# WIKI_ROOT=
